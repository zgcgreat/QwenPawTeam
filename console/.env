# ============================================
# QwenPaw Console (Frontend) Environment Variables
# Loaded automatically by Vite
# ============================================

# Multi-tenant frontend plugin activation
# Must match backend QWENPAW_MULTI_TENANT_ENABLED setting
VITE_MULTI_TENANT_ENABLED=true

# SSO cookie names forwarded as X-Forwarded-* headers (comma-separated)
# Leave empty if not using SSO integration
VITE_SSO_COOKIE_NAMES=
