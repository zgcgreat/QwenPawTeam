# ============================================
# QwenPaw Backend Environment Variables
# ============================================

# Multi-user plugin activation
# Set to "true" to enable multi-user support
QWENPAW_MULTI_USER_ENABLED=true
QWENPAW_AUTH_ENABLED=true

# 配置用户隔离字段（逗号分隔，默认 username）
QWENPAW_USER_FIELDS=sysId,branchId

# 配置中文标签（JSON，可选，仅覆盖需要自定义的）
QWENPAW_USER_FIELD_LABELS_ZH={"sysId":"系统编号","branchId":"分行号"}

# 配置英文标签（JSON，可选）
QWENPAW_USER_FIELD_LABELS_EN={"sysId":"System ID","branchId":"Branch ID"}

# 配置日文标签（JSON，可选）
QWENPAW_USER_FIELD_LABELS_JA={"sysId":"システムID","branchId":"支店ID"}

# 配置俄文标签（JSON，可选）
QWENPAW_USER_FIELD_LABELS_RU={"sysId":"ИД системы","branchId":"ИД филиала"}
